APP_NAME=EduChat RAG
APP_ENV=dev
SECRET_KEY=super-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=sqlite:///./app.db

CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=edu_documents

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

LLM_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_DUAL_ENABLE=true
LLM_SECONDARY_PROVIDER=groq
LLM_SECONDARY_API_KEY=
LLM_SECONDARY_MODEL=openai/gpt-oss-20b

RAG_TOP_K=4
RAG_CHUNK_SIZE_WORDS=500
RAG_CHUNK_OVERLAP_WORDS=50
RAG_CANDIDATE_POOL=24
RAG_HYBRID_ALPHA=0.55
RAG_ENABLE_HYBRID=true
RAG_ENABLE_QUERY_EXPANSION=true
RAG_ENABLE_RERANK=false
RAG_RERANKER_MODEL=cross-encoder/stsb-xlm-r-multilingual
RAG_QUERY_EXPANSION_LIMIT=2
RAG_TEMPERATURE=0.2
RAG_MAX_OUTPUT_TOKENS=500

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=student
USER_PASSWORD=123456
ANONYMOUS_QUESTION_LIMIT=5

CORS_ORIGINS=http://localhost:5173
